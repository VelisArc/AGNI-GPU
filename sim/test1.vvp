#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2009.vpi";
S_0x55ed10355490 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x55ed10355620 .scope module, "tb_minimal" "tb_minimal" 3 4;
 .timescale -9 -12;
v0x55ed103557b0_0 .var "clk", 0 0;
    .scope S_0x55ed10355620;
T_0 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x55ed103557b0_0, 0, 1;
    %end;
    .thread T_0;
    .scope S_0x55ed10355620;
T_1 ;
    %delay 1000, 0;
    %load/vec4 v0x55ed103557b0_0;
    %inv;
    %store/vec4 v0x55ed103557b0_0, 0, 1;
    %jmp T_1;
    .thread T_1;
    .scope S_0x55ed10355620;
T_2 ;
    %vpi_call/w 3 10 "$display", "==========================================" {0 0 0};
    %vpi_call/w 3 11 "$display", " AGNI: IcarusVerilog basic test" {0 0 0};
    %vpi_call/w 3 12 "$display", "==========================================" {0 0 0};
    %delay 10000, 0;
    %vpi_call/w 3 14 "$display", "[PASS] IcarusVerilog is working!" {0 0 0};
    %vpi_call/w 3 15 "$display", "==========================================" {0 0 0};
    %vpi_call/w 3 16 "$finish" {0 0 0};
    %end;
    .thread T_2;
# The file index is used to find the file name in the following table.
:file_names 4;
    "N/A";
    "<interactive>";
    "-";
    "tb/tb_minimal.v";
